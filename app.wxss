page {
  min-height: 100vh;
  background-color: #fff7d7;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

view,
text,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 32rpx 48rpx;
  background-color: #fff7d7;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.muted {
  color: #6b7280;
}

.primary-gradient {
  background: linear-gradient(135deg, #fde047 0%, #facc15 100%);
}

.card-shadow {
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.07);
}
