.favorites-page {
  padding-bottom: 88rpx;
}

.favorites-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.favorites-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.favorites-total {
  min-width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.favorite-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.favorite-tab {
  height: 58rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #6b7280;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.favorite-tab-active {
  background: #ffffff;
  color: #111827;
  box-shadow: 0 12rpx 28rpx rgba(120, 53, 15, 0.08);
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 58rpx 34rpx;
  border-radius: 30rpx;
  background: #ffffff;
  text-align: center;
}

.empty-image {
  display: block;
  width: 260rpx;
  height: 190rpx;
}

.empty-title {
  margin-top: 12rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.45;
}

.empty-button {
  width: 180rpx;
  height: 64rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #facc15;
  color: #78350f;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 64rpx;
}

.favorite-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.favorite-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  min-height: 164rpx;
  padding: 22rpx 96rpx 22rpx 22rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

.favorite-thumb {
  width: 120rpx;
  height: 120rpx;
  flex: 0 0 auto;
  border-radius: 22rpx;
  background: #fff7d6;
}

.favorite-thumb-text {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #92400e;
  font-size: 36rpx;
  font-weight: 900;
}

.favorite-body {
  min-width: 0;
  flex: 1;
}

.favorite-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.favorite-title {
  overflow: hidden;
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-type {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 20rpx;
  font-weight: 800;
}

.favorite-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  overflow: hidden;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.38;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.favorite-action {
  margin-top: 12rpx;
  color: #92400e;
  font-size: 22rpx;
  font-weight: 800;
}

.favorite-remove {
  position: absolute;
  top: 24rpx;
  right: 22rpx;
  width: 68rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 44rpx;
}
