<view class="page favorites-page">
  <view class="favorites-head">
    <view>
      <view class="section-title">我的收藏</view>
      <view class="favorites-subtitle">收藏过的记录和模板都在这里</view>
    </view>
    <view class="favorites-total">{{favorites.length}}</view>
  </view>

  <view class="favorite-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="favorite-tab {{activeType === item.id ? 'favorite-tab-active' : ''}}"
      data-type="{{item.id}}"
      bindtap="handleTabTap"
    >
      {{item.name}}
    </view>
  </view>

  <view wx:if="{{favorites.length === 0}}" class="empty-card card-shadow">
    <image class="empty-image" src="/assets/empty/empty-records.png" mode="aspectFit"></image>
    <view class="empty-title">暂无收藏</view>
    <view class="empty-desc">可以在创作记录或灵感广场里点收藏。</view>
    <button class="empty-button" bindtap="goExplore">去看看</button>
  </view>

  <view wx:else class="favorite-list">
    <view
      wx:for="{{favorites}}"
      wx:key="favoriteId"
      class="favorite-card card-shadow"
      data-index="{{index}}"
      bindtap="handleFavoriteTap"
    >
      <image wx:if="{{item.image}}" class="favorite-thumb" src="{{item.image}}" mode="aspectFill"></image>
      <view wx:else class="favorite-thumb favorite-thumb-text">{{item.thumbText}}</view>
      <view class="favorite-body">
        <view class="favorite-top">
          <view class="favorite-title">{{item.title}}</view>
          <view class="favorite-type">{{item.typeName}}</view>
        </view>
        <view class="favorite-desc">{{item.desc}}</view>
        <view class="favorite-action">{{item.actionText}}</view>
      </view>
      <button class="favorite-remove" catchtap="handleRemove" data-index="{{index}}">取消</button>
    </view>
  </view>
</view>
