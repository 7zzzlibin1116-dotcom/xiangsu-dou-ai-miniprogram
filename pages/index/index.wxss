.index-page {
  padding-bottom: 72rpx;
}

.hero {
  position: relative;
  height: 244rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background: #ffd51a;
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

.category-row {
  display: flex;
  justify-content: space-between;
  padding: 2rpx 0 8rpx;
}

.category-pill {
  width: calc((100% - 36rpx) / 4);
  height: 64rpx;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #92400e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 64rpx;
  text-align: center;
}

.category-pill-active {
  background: #fef3c7;
  color: #92400e;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.section-head {
  margin: 26rpx 0 20rpx;
}

.skills-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.skill-card {
  width: calc((100% - 22rpx) / 2);
  min-height: 240rpx;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

.skill-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: transparent;
  color: #b45309;
  font-size: 26rpx;
  font-weight: 800;
}

.skill-icon-image {
  display: block;
  width: 64rpx;
  height: 64rpx;
}

.skill-title {
  margin-top: 18rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.25;
}

.skill-desc {
  display: -webkit-box;
  min-height: 64rpx;
  margin-top: 10rpx;
  overflow: hidden;
  color: #6b7280;
  font-size: 23rpx;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #fff7d6;
  color: #92400e;
  font-size: 20rpx;
  line-height: 1;
}
