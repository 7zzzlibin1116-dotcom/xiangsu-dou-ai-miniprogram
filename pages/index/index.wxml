<view class="page index-page">
  <swiper class="hero card-shadow" autoplay circular interval="3500" duration="500" indicator-dots indicator-color="rgba(255,255,255,0.55)" indicator-active-color="#ffffff">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="hero-slide" data-type="{{item.type}}" data-skill-id="{{item.skillId}}" bindtap="handleBannerTap">
        <image class="hero-image" src="{{item.image}}" mode="aspectFill"></image>
      </view>
    </swiper-item>
  </swiper>

  <view class="category-row">
    <button
      wx:for="{{categories}}"
      wx:key="id"
      class="category-pill {{activeCategory === item.id ? 'category-pill-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="handleCategoryChange"
    >
      {{item.name}}
    </button>
  </view>

  <view class="section-head">
    <view class="section-title">热门 Skills</view>
  </view>

  <view class="skills-grid">
    <view
      wx:for="{{filteredSkills}}"
      wx:key="id"
      class="skill-card card-shadow"
      data-id="{{item.id}}"
      bindtap="handleSkillTap"
    >
      <view wx:if="{{item.badge}}" class="skill-badge">{{item.badge}}</view>
      <view class="skill-icon">
        <image wx:if="{{item.iconImage}}" class="skill-icon-image" src="{{item.iconImage}}" mode="aspectFit"></image>
        <text wx:else>{{item.icon}}</text>
      </view>
      <view class="skill-title">{{item.title}}</view>
      <view class="skill-desc">{{item.description}}</view>
      <view class="tag-row">
        <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
      </view>
    </view>
  </view>
</view>
