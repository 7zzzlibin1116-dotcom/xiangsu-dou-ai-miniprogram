<view class="page profile-page">
  <view class="profile-bg-dots">
    <view class="bg-pixel bg-pixel-1"></view>
    <view class="bg-pixel bg-pixel-2"></view>
    <view class="bg-pixel bg-pixel-3"></view>
    <view class="bg-pixel bg-pixel-4"></view>
    <view class="bg-pixel bg-pixel-5"></view>
    <view class="bg-pixel bg-pixel-6"></view>
  </view>

  <view class="profile-card card-shadow">
    <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
    <view class="profile-main">
      <view class="nickname-row">
        <view class="nickname">{{nickName}}</view>
      </view>
      <view class="profile-desc">{{loggedIn ? '欢迎使用像素豆 AI' : '登录后同步创作记录和积分'}}</view>
      <view class="member-row">
        <view class="member-badge">
          <text>{{memberLevel}}</text>
        </view>
        <view class="member-expire">到期：{{memberExpireText}}</view>
        <button wx:if="{{!loggedIn}}" class="login-button" bindtap="handleLogin">微信登录</button>
        <view wx:else class="upgrade-link" bindtap="goMembership">会员充值 ›</view>
      </view>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-card card-shadow">
      <image class="stat-icon" src="/assets/membership/benefit-coin.png" mode="aspectFit"></image>
      <view class="stat-value">{{points}}</view>
      <view class="stat-label">当前积分</view>
    </view>
    <view class="stat-card card-shadow">
      <image class="stat-icon" src="/assets/common/success.png" mode="aspectFit"></image>
      <view class="stat-value">{{totalCount}}</view>
      <view class="stat-label">总创作次数</view>
    </view>
  </view>

  <view class="menu-card card-shadow">
    <view class="menu-item" bindtap="goMembership">
      <view class="menu-left">
        <image class="menu-icon menu-icon-vip" src="/assets/common/vip.png" mode="aspectFit"></image>
        <view class="menu-title">会员充值</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goTopup">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/membership/benefit-coin.png" mode="aspectFit"></image>
        <view class="menu-title">积分加油包</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/favorite.png" mode="aspectFit"></image>
        <view class="menu-title">我的收藏</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goContact">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/service.png" mode="aspectFit"></image>
        <view class="menu-title">联系客服</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item menu-item-last" bindtap="goAbout">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/about.png" mode="aspectFit"></image>
        <view class="menu-title">关于我们</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>
</view>
