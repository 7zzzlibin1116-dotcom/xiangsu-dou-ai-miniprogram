.topup-page {
  min-height: 100vh;
  padding: 88rpx 32rpx 56rpx;
  background-color: #fff7d7;
}

.top-bar {
  display: flex;
  align-items: center;
  min-height: 64rpx;
}

.back-hit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 58rpx;
  color: #78350f;
  font-size: 26rpx;
  font-weight: 800;
}

.title-block {
  margin-top: 18rpx;
  text-align: center;
}

.page-title {
  color: #facc15;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.15;
  text-shadow:
    2rpx 0 #111827,
    -2rpx 0 #111827,
    0 2rpx #111827,
    0 -2rpx #111827,
    4rpx 4rpx 0 #92400e;
}

.page-subtitle {
  margin-top: 16rpx;
  color: #78350f;
  font-size: 26rpx;
}

.wallet-card,
.form-card,
.rule-card {
  border-radius: 28rpx;
  background: #ffffff;
}

.wallet-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 158rpx;
  margin-top: 34rpx;
  padding: 26rpx;
}

.wallet-icon {
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 auto;
}

.wallet-main {
  min-width: 0;
  flex: 1;
}

.wallet-label {
  color: #6b7280;
  font-size: 23rpx;
}

.wallet-value {
  margin-top: 8rpx;
  color: #f97316;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.member-pill {
  flex: 0 0 auto;
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff4c2;
  color: #78350f;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.form-card {
  margin-top: 28rpx;
  padding: 30rpx 28rpx;
}

.field-label {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.amount-row {
  display: flex;
  align-items: center;
  height: 116rpx;
  margin-top: 22rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #fffaf0;
}

.amount-symbol {
  color: #f97316;
  font-size: 42rpx;
  font-weight: 900;
}

.amount-input {
  min-width: 0;
  flex: 1;
  height: 100%;
  margin-left: 16rpx;
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
}

.input-placeholder {
  color: #c5a56b;
  font-weight: 600;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  border-radius: 999rpx;
  background: #fff4c2;
  color: #78350f;
  font-size: 24rpx;
  font-weight: 800;
}

.points-preview {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 10rpx;
  margin-top: 30rpx;
  color: #374151;
  font-size: 25rpx;
}

.points-number {
  color: #f97316;
  font-size: 46rpx;
  font-weight: 900;
}

.rule-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.rule-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
}

.rule-line {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.topup-button {
  width: 100%;
  height: 88rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  color: #78350f;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.topup-button-disabled {
  opacity: 0.68;
}
