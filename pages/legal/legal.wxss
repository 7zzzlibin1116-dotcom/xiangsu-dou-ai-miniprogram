.legal-page {
  padding-top: 40rpx;
  padding-bottom: 72rpx;
}

.legal-card {
  padding: 36rpx 32rpx 44rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.95);
}

.legal-head {
  padding-bottom: 26rpx;
  border-bottom: 1rpx solid rgba(146, 64, 14, 0.1);
}

.legal-title {
  color: #111827;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
}

.legal-date {
  margin-top: 14rpx;
  color: #92400e;
  font-size: 24rpx;
  font-weight: 700;
}

.legal-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff7d7;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.legal-section {
  margin-top: 32rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.4;
}

.section-paragraph {
  margin-top: 16rpx;
  color: #374151;
  font-size: 26rpx;
  line-height: 1.78;
}
