<view class="page skill-page">
  <view class="exit-button" bindtap="handleExit">×</view>

  <view class="skill-header">
    <view class="skill-icon">
      <image wx:if="{{skill.iconImage}}" class="skill-icon-image" src="{{skill.iconImage}}" mode="aspectFit"></image>
      <text wx:else>{{skill.icon || 'AI'}}</text>
    </view>
    <view class="skill-meta">
      <view class="skill-title">{{skill.title || '像素豆 AI'}}</view>
      <view class="skill-desc">{{skill.description || '让 AI 使用起来更简单'}}</view>
    </view>
  </view>

  <view wx:if="{{isUnavailableSkill}}" class="form-card card-shadow unavailable-card">
    <view class="unavailable-icon">!</view>
    <view class="unavailable-title">暂未开放</view>
    <view class="unavailable-desc">这个 Skill 正在打磨中，开放后就可以直接使用。</view>
  </view>

  <view wx:elif="{{isMarketingFormSkill}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 上传视觉素材</view>
      <button class="upload-box {{uploadedImages.length ? 'upload-box-filled' : ''}}" bindtap="handleChooseImage">
        <view wx:if="{{uploadedImages.length}}" class="uploaded-grid">
          <image wx:for="{{uploadedImages}}" wx:key="*this" class="uploaded-grid-image" src="{{item}}" mode="aspectFill"></image>
          <view wx:if="{{uploadedImages.length < 9}}" class="uploaded-add">+</view>
        </view>
        <view wx:else class="upload-placeholder">
          <image class="upload-icon" src="/assets/common/upload.png" mode="aspectFit"></image>
          <view class="upload-text">上传视觉素材</view>
        </view>
      </button>
    </view>

    <view class="field-block">
      <view class="field-label">二. 选择生成图片比例</view>
      <view class="ratio-grid">
        <view
          wx:for="{{imageRatios}}"
          wx:key="*this"
          class="ratio-chip {{selectedImageRatio === item ? 'ratio-chip-active' : ''}}"
          data-ratio="{{item}}"
          bindtap="handleRatioSelect"
        >
          {{item}}
        </view>
      </view>
      <input
        wx:if="{{marketingForm.noteStyle === '自定义'}}"
        class="custom-style-input"
        value="{{marketingForm.customStyle}}"
        data-field="customStyle"
        placeholder="{{customStylePlaceholder}}"
        placeholder-class="input-placeholder"
        bindinput="handleMarketingInput"
      />
    </view>

    <view class="field-block">
      <view class="field-line">
        <view class="field-label field-label-inline">三. 门店信息 <text class="optional-text">选填</text></view>
        <button class="fill-last-button" bindtap="handleFillLastMarketing">一键填入上次内容</button>
      </view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">1. 城市<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.city}}" data-field="city" placeholder="请输入城市" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">2. 商圈<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.businessArea}}" data-field="businessArea" placeholder="请输入商圈" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">3. 行业<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.industry}}" data-field="industry" placeholder="请输入行业" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">4. 品类<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.category}}" data-field="category" placeholder="请输入品类" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">5. 品牌名称<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.brandName}}" data-field="brandName" placeholder="请输入品牌名称" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">四. 选择{{marketingStyleLabel}}</view>
      <view class="style-grid">
        <view
          wx:for="{{noteStyles}}"
          wx:key="*this"
          class="style-chip {{marketingForm.noteStyle === item ? 'style-chip-active' : ''}}"
          data-style="{{item}}"
          bindtap="handleStyleSelect"
        >
          {{item}}
        </view>
      </view>
      <input
        wx:if="{{hasCustomStyle && marketingForm.noteStyle === '自定义'}}"
        class="custom-style-input"
        value="{{marketingForm.customStyle}}"
        data-field="customStyle"
        placeholder="{{customStylePlaceholder}}"
        placeholder-class="input-placeholder"
        bindinput="handleMarketingInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">五. 补充核心卖点</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{marketingForm.sellingPoints}}"
        data-field="sellingPoints"
        placeholder="活动日期/套餐价格/活动规则等等"
        placeholder-class="input-placeholder"
        bindinput="handleMarketingInput"
      ></textarea>
      <view class="input-count">{{marketingForm.sellingPoints.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isHolidayCampaign}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 填写节日营销信息 <text class="optional-text">选填</text></view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">1. 行业<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.industry}}" data-field="industry" placeholder="请输入行业" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">2. 品类<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.category}}" data-field="category" placeholder="请输入品类" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">3. 品牌名称<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.brandName}}" data-field="brandName" placeholder="请输入品牌名称" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">4. 节日<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.festival}}" data-field="festival" placeholder="例如：端午节、七夕、国庆" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">二. 补充需求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：活动预算、套餐价格、目标客群、门店特色"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isHotspotTracker}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 选择行业与品类 <text class="optional-text">选填</text></view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">1. 行业<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.industry}}" data-field="industry" placeholder="请输入行业" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
        <view class="store-field">
          <view class="store-label">2. 品类<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.category}}" data-field="category" placeholder="请输入品类" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">二. 选择生成风格</view>
      <view class="style-grid">
        <view
          wx:for="{{hotspotStyles}}"
          wx:key="*this"
          class="style-chip {{marketingForm.hotspotStyle === item ? 'style-chip-active' : ''}}"
          data-style="{{item}}"
          bindtap="handleHotspotStyleSelect"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">三. 补充需求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：帮我找近期适合做小红书/朋友圈内容的热点角度"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isCommunityBroadcast}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 品牌名称 <text class="optional-text">选填</text></view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">品牌名称<text class="store-optional">选填</text>：</view>
          <input class="store-input" value="{{marketingForm.brandName}}" data-field="brandName" placeholder="请输入品牌名称" placeholder-class="input-placeholder" bindinput="handleMarketingInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">二. 选择群发风格</view>
      <view class="style-grid">
        <view
          wx:for="{{noteStyles}}"
          wx:key="*this"
          class="style-chip {{marketingForm.noteStyle === item ? 'style-chip-active' : ''}}"
          data-style="{{item}}"
          bindtap="handleStyleSelect"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">三. 补充需求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：活动内容、福利规则、发送对象、语气要求"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isTravelPlan}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 填写旅行信息</view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">1. 目的地：</view>
          <input class="store-input" value="{{travelForm.destination}}" data-field="destination" placeholder="请输入目的地" placeholder-class="input-placeholder" bindinput="handleTravelInput" />
        </view>
        <view class="store-field">
          <view class="store-label">2. 出发地：</view>
          <input class="store-input" value="{{travelForm.departure}}" data-field="departure" placeholder="请输入出发地" placeholder-class="input-placeholder" bindinput="handleTravelInput" />
        </view>
        <view class="store-field">
          <view class="store-label">3. 旅行天数：</view>
          <input class="store-input" value="{{travelForm.days}}" data-field="days" placeholder="例如：3天2晚" placeholder-class="input-placeholder" bindinput="handleTravelInput" />
        </view>
        <view class="store-field">
          <view class="store-label">4. 预算：</view>
          <input class="store-input" value="{{travelForm.budget}}" data-field="budget" placeholder="例如：3000元/人" placeholder-class="input-placeholder" bindinput="handleTravelInput" />
        </view>
        <view class="store-field">
          <view class="store-label">5. 同行人群：</view>
          <input class="store-input" value="{{travelForm.companions}}" data-field="companions" placeholder="例如：情侣、亲子、朋友" placeholder-class="input-placeholder" bindinput="handleTravelInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">二. 选择旅行风格</view>
      <view class="style-grid">
        <view
          wx:for="{{travelStyles}}"
          wx:key="*this"
          class="style-chip {{travelForm.style === item ? 'style-chip-active' : ''}}"
          data-style="{{item}}"
          bindtap="handleTravelStyleSelect"
        >
          {{item}}
        </view>
      </view>
      <input
        wx:if="{{travelForm.style === '自定义'}}"
        class="custom-style-input"
        value="{{travelForm.customStyle}}"
        data-field="customStyle"
        placeholder="请输入自定义旅行风格"
        placeholder-class="input-placeholder"
        bindinput="handleTravelInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">三. 补充需求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：不想太累、想住市中心、需要避开人多景点"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isRecipeHelper}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 现有食材</view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">1. 肉类：</view>
          <input class="store-input" value="{{recipeForm.meat}}" data-field="meat" placeholder="例如：鸡胸肉、牛肉、虾" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">2. 蔬菜：</view>
          <input class="store-input" value="{{recipeForm.vegetables}}" data-field="vegetables" placeholder="例如：番茄、土豆、青菜" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">3. 蛋奶：</view>
          <input class="store-input" value="{{recipeForm.eggDairy}}" data-field="eggDairy" placeholder="例如：鸡蛋、牛奶、芝士" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">4. 主食：</view>
          <input class="store-input" value="{{recipeForm.staple}}" data-field="staple" placeholder="例如：米饭、面条、馒头" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">二. 用餐信息</view>
      <view class="store-form">
        <view class="store-field">
          <view class="store-label">1. 几个人吃：</view>
          <input class="store-input" value="{{recipeForm.people}}" data-field="people" placeholder="例如：2人" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">2. 做几道菜：</view>
          <input class="store-input" value="{{recipeForm.dishes}}" data-field="dishes" placeholder="例如：3道菜" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">3. 做饭时间：</view>
          <input class="store-input" value="{{recipeForm.cookingTime}}" data-field="cookingTime" placeholder="例如：30分钟内" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">4. 口味偏好：</view>
          <input class="store-input" value="{{recipeForm.taste}}" data-field="taste" placeholder="例如：清淡、微辣、下饭" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">5. 厨房工具：</view>
          <input class="store-input" value="{{recipeForm.tools}}" data-field="tools" placeholder="例如：空气炸锅、电饭煲、炒锅" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
        <view class="store-field">
          <view class="store-label">6. 忌口：</view>
          <input class="store-input" value="{{recipeForm.taboo}}" data-field="taboo" placeholder="例如：不吃香菜、少油、过敏" placeholder-class="input-placeholder" bindinput="handleRecipeInput" />
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">三. 补充需求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：想要适合带饭、低脂、高蛋白、孩子爱吃"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isHighEqReply}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 选择回复场景</view>
      <view class="style-grid">
        <view
          wx:for="{{highEqScenarios}}"
          wx:key="*this"
          class="style-chip high-eq-chip {{highEqForm.scenario === item ? 'style-chip-active' : ''}}"
          data-scenario="{{item}}"
          bindtap="handleHighEqScenarioSelect"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">二. 对方消息</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{highEqForm.message}}"
        data-field="message"
        placeholder="粘贴对方发来的消息，或描述当前情况"
        placeholder-class="input-placeholder"
        bindinput="handleHighEqInput"
      ></textarea>
      <view class="input-count">{{highEqForm.message.length}}/500</view>
    </view>

    <view class="field-block">
      <view class="field-label">三. 补充要求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：语气委婉一点、简短一点、带一点幽默感"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isTryOn}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 上传衣服照片</view>
      <button class="upload-box {{tryOnImages.clothing.length ? 'upload-box-filled' : ''}}" data-field="clothing" bindtap="handleChooseTryOnImage">
        <image wx:if="{{tryOnImages.clothing.length}}" class="uploaded-image" src="{{tryOnImages.clothing[0]}}" mode="aspectFill"></image>
        <view wx:else class="upload-placeholder">
          <image class="upload-icon" src="/assets/common/upload.png" mode="aspectFit"></image>
          <view class="upload-text">上传衣服照片</view>
        </view>
      </button>
    </view>

    <view class="field-block">
      <view class="field-label">二. 上传本人照片</view>
      <button class="upload-box {{tryOnImages.person.length ? 'upload-box-filled' : ''}}" data-field="person" bindtap="handleChooseTryOnImage">
        <image wx:if="{{tryOnImages.person.length}}" class="uploaded-image" src="{{tryOnImages.person[0]}}" mode="aspectFill"></image>
        <view wx:else class="upload-placeholder">
          <image class="upload-icon" src="/assets/common/upload.png" mode="aspectFit"></image>
          <view class="upload-text">上传本人照片</view>
        </view>
      </button>
    </view>

    <view class="field-block">
      <view class="field-label">三. 补充需求</view>
      <textarea
        class="prompt-input"
        maxlength="500"
        value="{{prompt}}"
        placeholder="例如：保留原衣服颜色、真人自然试穿、背景干净"
        placeholder-class="input-placeholder"
        bindinput="handlePromptInput"
      ></textarea>
      <view class="input-count">{{prompt.length}}/500</view>
    </view>

    <view
      class="generate-button {{generating ? 'generate-button-disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <image class="button-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <text>{{generating ? '生成中...' : '立即生成'}}</text>
    </view>
  </view>

  <view wx:elif="{{isFashionRender}}" class="form-card card-shadow">
    <view class="field-block">
      <view class="field-label">一. 上传服装线稿</view>
      <button class="upload-box {{uploadedImages.length ? 'upload-box-filled' : ''}}" bindtap="handleChooseImage">
