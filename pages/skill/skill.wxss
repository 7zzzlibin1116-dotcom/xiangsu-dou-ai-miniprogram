.skill-page {
  padding-top: 0;
  padding-bottom: 72rpx;
}

.exit-button {
  position: fixed;
  top: 92rpx;
  left: 32rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(120, 53, 15, 0.08);
}

.skill-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 170rpx 0 28rpx;
}

.skill-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  flex: 0 0 auto;
  border-radius: 28rpx;
  background: transparent;
  color: #92400e;
  font-size: 34rpx;
  font-weight: 800;
}

.skill-icon-image {
  display: block;
  width: 82rpx;
  height: 82rpx;
}

.skill-meta {
  min-width: 0;
}

.skill-title {
  color: #111827;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.skill-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.4;
}

.form-card,
.result-card {
  padding: 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
}

.unavailable-card {
  display: flex;
  min-height: 320rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.unavailable-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 50rpx;
  font-weight: 900;
}

.unavailable-title {
  margin-top: 24rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.unavailable-desc {
  max-width: 460rpx;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.field-block + .field-block {
  margin-top: 28rpx;
}

.field-label {
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
}

.field-hint {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.field-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.field-label-inline {
  margin-bottom: 0;
}

.fill-last-button {
  width: 190rpx;
  height: 54rpx;
  flex: 0 0 auto;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 54rpx;
}

.upload-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  border: 2rpx dashed #facc15;
  border-radius: 28rpx;
  background: #fffdf2;
}

.upload-box-filled {
  border-style: solid;
  background: #ffffff;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.uploaded-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: 12rpx;
  width: 100%;
  height: 100%;
  padding: 14rpx;
}

.uploaded-grid-image,
.uploaded-add {
  width: 100%;
  height: 100%;
  min-height: 78rpx;
  border-radius: 18rpx;
}

.uploaded-grid-image {
  background: #fff7d6;
}

.uploaded-add {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #facc15;
  color: #92400e;
  font-size: 40rpx;
  font-weight: 900;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #92400e;
}

.upload-icon {
  display: block;
  width: 92rpx;
  height: 92rpx;
}

.upload-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.store-form {
  border-radius: 24rpx;
  background: #fffaf0;
  padding: 8rpx 22rpx;
}

.store-field {
  display: flex;
  align-items: center;
  min-height: 82rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.store-field:last-child {
  border-bottom: 0;
}

.store-label {
  width: 210rpx;
  flex: 0 0 auto;
  color: #374151;
  font-size: 24rpx;
  font-weight: 700;
}

.optional-text,
.store-optional {
  color: #9ca3af;
  font-weight: 600;
}

.optional-text {
  margin-left: 8rpx;
  font-size: 22rpx;
}

.store-optional {
  margin-left: 4rpx;
  font-size: 19rpx;
}

.store-input {
  min-width: 0;
  flex: 1;
  color: #111827;
  font-size: 25rpx;
}

.style-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  column-gap: 10rpx;
  row-gap: 14rpx;
}

.dianping-category-block {
  margin-bottom: 28rpx;
}

.ratio-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.ratio-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc((100% - 28rpx) / 3);
  height: 58rpx;
  border-radius: 999rpx;
  background: #fff7d6;
  color: #78350f;
  font-size: 23rpx;
  font-weight: 800;
}

.ratio-chip-active {
  background: #fef3c7;
  color: #92400e;
  box-shadow: inset 0 0 0 2rpx #facc15;
}

.style-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc((100% - 30rpx) / 4);
  min-width: 0;
  height: 56rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #fff7d6;
  color: #78350f;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.style-chip-active {
  background: #fef3c7;
  color: #92400e;
  box-shadow: inset 0 0 0 2rpx #facc15;
}

.high-eq-chip {
  width: calc((100% - 10rpx) / 2);
  font-size: 21rpx;
}

.custom-style-input {
  width: 100%;
  height: 78rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fffaf0;
  color: #111827;
  font-size: 25rpx;
}

.prompt-input {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffaf0;
  color: #111827;
  font-size: 26rpx;
  line-height: 1.45;
}

.prompt-input-small {
  min-height: 130rpx;
}

.input-placeholder {
  color: #9ca3af;
}

.input-count {
  margin-top: 12rpx;
  text-align: right;
  color: #9ca3af;
  font-size: 22rpx;
}

.generate-button,
.download-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fde047 0%, #facc15 100%);
  color: #78350f;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1;
}

.button-icon {
  display: block;
  width: 42rpx;
  height: 42rpx;
  margin-right: 10rpx;
}

.generate-button-disabled {
  opacity: 0.72;
}

.result-card {
  margin-top: 28rpx;
}

.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.result-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 800;
}

.result-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
  line-height: 1.4;
}

.done-badge {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 700;
}

.result-image {
  width: 100%;
  height: 420rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  background: #fff7d6;
}

.result-text-box {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fffaf0;
  color: #374151;
  font-size: 25rpx;
  line-height: 1.6;
  white-space: pre-line;
}

.download-button {
  margin-top: 24rpx;
  background: #facc15;
}
