<view class="page profile-page">
  <view class="profile-bg-dots">
    <view class="bg-pixel bg-pixel-1"></view>
    <view class="bg-pixel bg-pixel-2"></view>
    <view class="bg-pixel bg-pixel-3"></view>
    <view class="bg-pixel bg-pixel-4"></view>
    <view class="bg-pixel bg-pixel-5"></view>
    <view class="bg-pixel bg-pixel-6"></view>
  </view>

  <view class="profile-card card-shadow">
    <image class="avatar-image" src="/assets/profile/avatar-pixel.png" mode="aspectFill"></image>
    <view class="profile-main">
      <view class="nickname-row">
        <view class="nickname">微信用户</view>
        <view class="edit-icon">✎</view>
      </view>
      <view class="profile-desc">欢迎使用像素豆 AI</view>
      <view class="member-row">
        <view class="member-badge">
          <text class="member-crown">♛</text>
          <text>普通会员</text>
        </view>
        <view class="upgrade-link" bindtap="handleMenuTap" data-title="我的会员">去升级 ›</view>
      </view>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-card card-shadow">
      <image class="stat-icon" src="/assets/common/magic-generate.png" mode="aspectFit"></image>
      <view class="stat-value">{{todayLeft}}</view>
      <view class="stat-label">今日剩余次数 <text class="stat-help">?</text></view>
    </view>
    <view class="stat-card card-shadow">
      <image class="stat-icon" src="/assets/common/success.png" mode="aspectFit"></image>
      <view class="stat-value">{{totalCount}}</view>
      <view class="stat-label">总创作次数</view>
    </view>
  </view>

  <view class="menu-card card-shadow">
    <view class="menu-item" bindtap="handleMenuTap" data-title="我的会员">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/vip.png" mode="aspectFit"></image>
        <view class="menu-title">我的会员</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="handleMenuTap" data-title="我的收藏">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/favorite.png" mode="aspectFit"></image>
        <view class="menu-title">我的收藏</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="handleMenuTap" data-title="联系客服">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/service.png" mode="aspectFit"></image>
        <view class="menu-title">联系客服</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item menu-item-last" bindtap="handleAbout">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/common/about.png" mode="aspectFit"></image>
        <view class="menu-title">关于像素豆 AI</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <image class="profile-banner card-shadow" src="/assets/backgrounds/profile-brand-banner.png" mode="aspectFill"></image>
</view>
